# Obrigatório para login (e-mail/senha + Google). Em produção (Vercel): Settings → Environment Variables
# → adicione estas chaves no ambiente Production e faça um novo deploy para o bundle enxergar os valores.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alternativa nova (equivalente à ANON em projetos novos da Supabase):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Supabase → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/callback
#   https://<seu-projeto>.vercel.app/auth/callback
# E-mails (separados por vírgula) que veem o toggle Dono/Prof/Aluno no app — só altera a UI.
NEXT_PUBLIC_DEV_ROOT_EMAILS=
#
# Dados reais no Supabase (alunos, aulas, financeiro): o Postgres usa RLS; login Google costuma vir SEM role no JWT.
# Cadastre o MESMO e-mail de login na tabela staff_access como admin (SQL Editor ou Dashboard):
#   INSERT INTO staff_access (id, email, role, is_active)
#   VALUES (gen_random_uuid()::text, 'voce@gmail.com', 'admin', true)
#   ON CONFLICT (email) DO UPDATE SET role = excluded.role, is_active = true;
# Depois disso, wt_is_staff() (migração 20260502100000) libera SELECT/UPDATE staff nas políticas.

# Dev/staging apenas: login enxuto + Google/Facebook sem abrir «Acesso da equipe». Nunca true em produção pública.
# NEXT_PUBLIC_LOGIN_OPERATOR_MODE=true

# Matrícula restrita: só aceita /cadastro quando há ?invite=… na URL (ou token já salvo na sessão da aba).
# Recomendado em produção quando o dono distribuir links assinados ou com slug único.
# NEXT_PUBLIC_REQUIRE_CADASTRO_INVITE=true

# Dev: mostrar no rodapé do login o link direto «Abrir matrícula». Em produção deixe desligado (padrão).
# NEXT_PUBLIC_SHOW_PUBLIC_CADASTRO_LINK=true

# Oráculo IA — análise preditiva no Cockpit (Anthropic Claude)
# Obtenha em: https://console.anthropic.com/settings/keys
# Sem esta chave, o Oráculo exibe insights estáticos de fallback.
ANTHROPIC_API_KEY=

# Web Push Notifications (VAPID)
# Gere as chaves com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu@email.com
# Chave service_role do Supabase (nunca exposta ao browser) — usada pelo /api/push/send
SUPABASE_SERVICE_ROLE_KEY=

# Padrão atual: SEM qualquer seed transacional mock (alunos/aulas/pagamentos/feed).
# Para manter explicitamente vazio em demos locais:
# NEXT_PUBLIC_EMPTY_LOCAL_SEED=1
# Só habilite seed fictício se quiser demo interna:
# NEXT_PUBLIC_ENABLE_DEMO_SEED=1

# Error Tracking (Sentry) — opcional mas recomendado em produção
# Crie conta grátis em https://sentry.io
# Crie projeto Next.js, copie o DSN:
NEXT_PUBLIC_SENTRY_DSN=
# Em Vercel: Settings → Environment Variables → adicionar NEXT_PUBLIC_SENTRY_DSN

# Analytics (PostHog) — opcional mas recomendado em produção
# Crie conta grátis em https://posthog.com
# Copie API key do projeto:
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
# Em Vercel: Settings → Environment Variables → adicionar ambos
