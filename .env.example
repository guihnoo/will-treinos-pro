# Obrigatório para login (e-mail/senha + Google). Em produção (Vercel): Settings → Environment Variables
# → adicione estas chaves no ambiente Production e faça um novo deploy para o bundle enxergar os valores.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alternativa nova (equivalente à ANON em projetos novos da Supabase):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Supabase → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/callback
#   https://<seu-projeto>.vercel.app/auth/callback
NEXT_PUBLIC_DEV_ROOT_EMAILS=

# Com NEXT_PUBLIC_SUPABASE_URL + chave pública configuradas, o app já inicia SEM alunos/aulas/pagamentos mock
# (seed transacional vazio até o fetch ao vivo). Para forçar seed vazio mesmo sem Supabase (demo limpo):
# NEXT_PUBLIC_EMPTY_LOCAL_SEED=1
